# Azure AI Foundry project endpoint (without /openai/v1/responses suffix)
FOUNDRY_PROJECT_ENDPOINT="https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT"
FOUNDRY_MODEL="gpt-5-mini"

# Override when the MCP server runs elsewhere (e.g. Azure Container Apps)
MCP_SERVER_URL="http://localhost:8000/mcp"

# Azure AI Search
AZURE_SEARCH_ENDPOINT="https://YOUR-SEARCH-SERVICE.search.windows.net"
AZURE_SEARCH_INDEX_NAME="your-index-name"

# Azure OpenAI – embedding model (authentication via DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-large"
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# Azure OpenAI – transcription model
AZURE_OPENAI_TRANSCRIPTION_MODEL="gpt-4o-transcribe-diarize"

# Azure Blob Storage – audio file containers (authentication via DefaultAzureCredential)
AZURE_STORAGE_ACCOUNT_NAME="your-storage-account"
AZURE_STORAGE_INPUT_CONTAINER="input"
AZURE_STORAGE_OUTPUT_CONTAINER="output"
